# Sisyphus Academica — Configuration
# Copy to .env and fill in

# === LITERATURE SEARCH APIs ===

# Optional: Semantic Scholar API key (increases rate limit)
SEMANTIC_SCHOLAR_API_KEY=

# Optional: CrossRef polite pool email (increases rate limit)
CROSSREF_EMAIL=your.email@example.com

# === HUMANIZER ===

# Path to Humanizer skill (default: ~/.config/opencode/skills/humanizer)
HUMANIZER_PATH=~/.config/opencode/skills/humanizer

# === VENUE ===

# Default venue target (neurips, icml, iclr, acl, nature, arxiv)
DEFAULT_VENUE=arxiv

# === VOICE ===

# Path to voice calibration sample (optional)
VOICE_SAMPLE_PATH=
